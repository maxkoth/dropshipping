# ============================================================
# Crypto Signal System — Environment Variables
# Copy to .env and fill in your keys.
# Never commit .env to git.
# ============================================================

# ── Claude / Anthropic API ───────────────────────────────────
# Required for signals/engine.js and signals/sentiment.js
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram Bot (alert-bot.js) ──────────────────────────────
# Create a bot via @BotFather on Telegram
# Get chat_id by messaging your bot and calling /getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# ── Discord Webhook (alert-bot.js) ───────────────────────────
# Create in Discord channel settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Solana RPC (production on-chain calls) ───────────────────
# Free: https://api.mainnet-beta.solana.com
# Paid (recommended): Helius, QuickNode, Triton
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=your-helius-key

# ── EVM RPC (Base + ETH for screener / sniper) ───────────────
# Free: Infura, Alchemy free tier
BASE_RPC_URL=https://mainnet.base.org
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
ALCHEMY_API_KEY=your-alchemy-key

# ── DEXScreener / GeckoTerminal (optional enhanced data) ─────
# DEXScreener public API is free, no key required
# GeckoTerminal API key for higher rate limits
GECKOTERMINAL_API_KEY=

# ── Nansen (whale tracking) ──────────────────────────────────
# https://nansen.ai — Pro plan required for Smart Money API
NANSEN_API_KEY=

# ── Arkham Intelligence ───────────────────────────────────────
# https://intel.arkm.com — API access via paid plan
ARKHAM_API_KEY=

# ── Twitter/X API (sentiment.js post scraping) ───────────────
# Bearer token from https://developer.twitter.com
TWITTER_BEARER_TOKEN=AAAA...

# ── Portfolio Settings ────────────────────────────────────────
# Starting capital for paper trading and risk sizing
PORTFOLIO_CAPITAL_USD=10000
